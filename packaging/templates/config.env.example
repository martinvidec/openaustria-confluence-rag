# Confluence RAG — configuration
# Auto-generated by `confluence-rag init`. Edit with `confluence-rag config edit`.

# -------- Confluence --------
CONFLUENCE_BASE_URL=http://localhost:8090

# Authentication — provide EITHER a PAT (Confluence 7.9+) OR username/password.
# Leave the unused one blank.
CONFLUENCE_PAT=
CONFLUENCE_USERNAME=
CONFLUENCE_PASSWORD=

# Comma-separated list of Space keys to index (e.g. "DEV,OPS,DOC")
CONFLUENCE_SPACES=

# -------- Ollama (LLM + embedding) --------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=gemma3:4b
OLLAMA_EMBEDDING_MODEL=bge-m3

# -------- Qdrant (vector store) --------
QDRANT_HOST=localhost
QDRANT_GRPC_PORT=6334

# -------- Embedding / Ingestion --------
# Must match the embedding model's dimension (bge-m3 = 1024, nomic-embed-text = 768)
VECTOR_DIMENSION=1024

# -------- Reranker --------
# Type: llm (default, uses Ollama) | infinity (external container) | none (off)
QUERY_RERANKER_TYPE=llm
QUERY_RERANKER_LLM_MODEL=qwen3:0.6b
QUERY_RERANKER_LLM_URL=http://localhost:11434

# -------- Query tuning --------
QUERY_TOP_K=5
QUERY_SIMILARITY_THRESHOLD=0.45
